<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1E1E1E"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:background="#2D2D2D"
        android:gravity="center_vertical"
        android:paddingLeft="4dp"
        android:paddingRight="4dp">

        <ImageButton
            android:id="@+id/btnMenu"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_menu_hamburger"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:padding="8dp"
            android:contentDescription="文件列表"/>

        <TextView
            android:id="@+id/projectNameText"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="项目名称"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:gravity="center_vertical"
            android:paddingLeft="4dp"
            android:paddingRight="4dp"
            android:singleLine="true"
            android:ellipsize="end"/>

        <ImageButton
            android:id="@+id/btnUndo"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_undo"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:padding="8dp"
            android:contentDescription="撤销"/>

        <ImageButton
            android:id="@+id/btnRedo"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_redo"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:padding="8dp"
            android:contentDescription="前进"/>

        <ImageButton
            android:id="@+id/btnRun"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_play"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:padding="8dp"
            android:contentDescription="运行"
            android:tint="#4CAF50"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:orientation="horizontal"
        android:background="#252525"
        android:gravity="center_vertical"
        android:paddingLeft="12dp"
        android:paddingRight="4dp">

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_file"
            android:tint="#888888"/>

        <TextView
            android:id="@+id/currentFileText"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="index.html"
            android:textColor="#CCCCCC"
            android:textSize="12sp"
            android:gravity="center_vertical"
            android:paddingLeft="6dp"
            android:singleLine="true"
            android:ellipsize="end"/>

        <ImageButton
            android:id="@+id/btnNewFile"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_add"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:padding="6dp"
            android:contentDescription="新建文件"
            android:tint="#4CAF50"/>

        <ImageButton
            android:id="@+id/btnSave"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_save"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:padding="6dp"
            android:contentDescription="保存"
            android:tint="#2196F3"/>
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:id="@+id/editorPanel"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:fillViewport="true">

                <com.xingyun.ide.CodeEditor
                    android:id="@+id/htmlEditor"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="500dp"
                    android:background="#1E1E1E"
                    android:textColor="#D4D4D4"
                    android:textColorHint="#808080"
                    android:textSize="14sp"
                    android:typeface="monospace"
                    android:gravity="top|start"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp"
                    android:paddingRight="8dp"
                    android:scrollbars="none"
                    android:inputType="textMultiLine|textNoSuggestions"
                    android:hint="编写代码..."/>
            </ScrollView>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/fileListPanel"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:background="#1E1E1E"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:orientation="horizontal"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"
                android:background="#2D2D2D"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="项目文件"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:drawableLeft="@drawable/ic_folder"
                    android:drawablePadding="8dp"/>

                <TextView
                    android:id="@+id/fileCountText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 个文件"
                    android:textColor="#888888"
                    android:textSize="11sp"/>
            </LinearLayout>

            <ListView
                android:id="@+id/fileListView"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:divider="#333333"
                android:dividerHeight="1dp"
                android:background="#1E1E1E"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="6dp"
                android:background="#252525"
                android:gravity="center">

                <ImageView
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:src="@drawable/ic_info"
                    android:tint="#666666"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="点击打开 | 长按管理"
                    android:textColor="#666666"
                    android:textSize="10sp"
                    android:layout_marginLeft="6dp"/>
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>

    <!-- 符号栏 - text 由 Java 代码设置 -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#252525"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:orientation="horizontal"
            android:paddingLeft="4dp"
            android:paddingRight="4dp"
            android:gravity="center_vertical">

            <Button android:id="@+id/sym_lt"    android:layout_width="36dp" android:layout_height="30dp" android:textSize="16sp" android:textColor="#FFFFFF" android:backgroundTint="#333333" android:minWidth="0dp" android:minHeight="0dp" android:layout_margin="1dp" android:textAllCaps="false"/>
            <Button android:id="@+id/sym_gt"    android:layout_width="36dp" android:layout_height="30dp" android:textSize="16sp" android:textColor="#FFFFFF" android:backgroundTint="#333333" android:minWidth="0dp" android:minHeight="0dp" android:layout_margin="1dp" android:textAllCaps="false"/>
            <Button android:id="@+id/sym_eq"    android:layout_width="36dp" android:layout_height="30dp" android:text="=" android:textSize="16sp" android:textColor="#FFFFFF" android:backgroundTint="#333333" android:minWidth="0dp" android:minHeight="0dp" android:layout_margin="1dp" android:textAllCaps="false"/>
            <Button android:id="@+id/sym_dq"    android:layout_width="36dp" android:layout_height="30dp" android:text='"' android:textSize="16sp" android:textColor="#FFFFFF" android:backgroundTint="#333333" android:minWidth="0dp" android:minHeight="0dp" android:layout_margin="1dp" android:textAllCaps="false"/>
            <Button android:id="@+id/sym_colon" android:layout_width="36dp" android:layout_height="30dp" android:text=":" android:textSize="16sp" android:textColor="#FFFFFF" android:backgroundTint="#333333" android:minWidth="0dp" android:minHeight="0dp" android:layout_margin="1dp" android:textAllCaps="false"/>
            <Button android:id="@+id/sym_comma" android:layout_width="36dp" android:layout_height="30dp" android:text="," android:textSize="16sp" android:textColor="#FFFFFF" android:backgroundTint="#333333" android:minWidth="0dp" android:minHeight="0dp" android:layout_margin="1dp" android:textAllCaps="false"/>
            <Button android:id="@+id/sym_dot"   android:layout_width="36dp" android:layout_height="30dp" android:text="." android:textSize="16sp" android:textColor="#FFFFFF" android:backgroundTint="#333333" android:minWidth="0dp" android:minHeight="0dp" android:layout_margin="1dp" android:textAllCaps="false"/>
            <Button android:id="@+id/sym_lb"    android:layout_width="36dp" android:layout_height="30dp" android:text="{" android:textSize="16sp" android:textColor="#FFFFFF" android:backgroundTint="#333333" android:minWidth="0dp" android:minHeight="0dp" android:layout_margin="1dp" android:textAllCaps="false"/>
            <Button android:id="@+id/sym_rb"    android:layout_width="36dp" android:layout_height="30dp" android:text="}" android:textSize="16sp" android:textColor="#FFFFFF" android:backgroundTint="#333333" android:minWidth="0dp" android:minHeight="0dp" android:layout_margin="1dp" android:textAllCaps="false"/>
            <Button android:id="@+id/sym_lp"    android:layout_width="36dp" android:layout_height="30dp" android:text="(" android:textSize="16sp" android:textColor="#FFFFFF" android:backgroundTint="#333333" android:minWidth="0dp" android:minHeight="0dp" android:layout_margin="1dp" android:textAllCaps="false"/>
            <Button android:id="@+id/sym_rp"    android:layout_width="36dp" android:layout_height="30dp" android:text=")" android:textSize="16sp" android:textColor="#FFFFFF" android:backgroundTint="#333333" android:minWidth="0dp" android:minHeight="0dp" android:layout_margin="1dp" android:textAllCaps="false"/>
            <Button android:id="@+id/sym_slash" android:layout_width="36dp" android:layout_height="30dp" android:text="/" android:textSize="16sp" android:textColor="#FFFFFF" android:backgroundTint="#333333" android:minWidth="0dp" android:minHeight="0dp" android:layout_margin="1dp" android:textAllCaps="false"/>
            <Button android:id="@+id/sym_bslash" android:layout_width="36dp" android:layout_height="30dp" android:text="\" android:textSize="16sp" android:textColor="#FFFFFF" android:backgroundTint="#333333" android:minWidth="0dp" android:minHeight="0dp" android:layout_margin="1dp" android:textAllCaps="false"/>
            <Button android:id="@+id/sym_qm"    android:layout_width="36dp" android:layout_height="30dp" android:text="?" android:textSize="16sp" android:textColor="#FFFFFF" android:backgroundTint="#333333" android:minWidth="0dp" android:minHeight="0dp" android:layout_margin="1dp" android:textAllCaps="false"/>
            <Button android:id="@+id/sym_pipe"  android:layout_width="36dp" android:layout_height="30dp" android:text="|" android:textSize="16sp" android:textColor="#FFFFFF" android:backgroundTint="#333333" android:minWidth="0dp" android:minHeight="0dp" android:layout_margin="1dp" android:textAllCaps="false"/>
            <Button android:id="@+id/sym_lbk"   android:layout_width="36dp" android:layout_height="30dp" android:text="[" android:textSize="16sp" android:textColor="#FFFFFF" android:backgroundTint="#333333" android:minWidth="0dp" android:minHeight="0dp" android:layout_margin="1dp" android:textAllCaps="false"/>
            <Button android:id="@+id/sym_rbk"   android:layout_width="36dp" android:layout_height="30dp" android:text="]" android:textSize="16sp" android:textColor="#FFFFFF" android:backgroundTint="#333333" android:minWidth="0dp" android:minHeight="0dp" android:layout_margin="1dp" android:textAllCaps="false"/>
            <Button android:id="@+id/sym_under" android:layout_width="36dp" android:layout_height="30dp" android:text="_" android:textSize="16sp" android:textColor="#FFFFFF" android:backgroundTint="#333333" android:minWidth="0dp" android:minHeight="0dp" android:layout_margin="1dp" android:textAllCaps="false"/>
            <Button android:id="@+id/sym_dash"  android:layout_width="36dp" android:layout_height="30dp" android:text="-" android:textSize="16sp" android:textColor="#FFFFFF" android:backgroundTint="#333333" android:minWidth="0dp" android:minHeight="0dp" android:layout_margin="1dp" android:textAllCaps="false"/>
        </LinearLayout>
    </HorizontalScrollView>

    <!-- 底部工具栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="4dp"
        android:background="#2D2D2D"
        android:gravity="center">

        <Button
            android:id="@+id/btnClear"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="清空"
            android:textColor="#FF9800"
            android:textSize="12sp"
            android:textAllCaps="false"
            android:backgroundTint="#333333"
            android:drawableLeft="@drawable/ic_delete"
            android:drawablePadding="4dp"
            android:layout_margin="2dp"
            android:minHeight="0dp"/>

        <Button
            android:id="@+id/btnFormat"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="格式化"
            android:textColor="#9C27B0"
            android:textSize="12sp"
            android:textAllCaps="false"
            android:backgroundTint="#333333"
            android:drawableLeft="@drawable/ic_format"
            android:drawablePadding="4dp"
            android:layout_margin="2dp"
            android:minHeight="0dp"/>

        <Button
            android:id="@+id/btnSearch"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="查找"
            android:textColor="#2196F3"
            android:textSize="12sp"
            android:textAllCaps="false"
            android:backgroundTint="#333333"
            android:drawableLeft="@drawable/ic_search"
            android:drawablePadding="4dp"
            android:layout_margin="2dp"
            android:minHeight="0dp"/>
    </LinearLayout>
</LinearLayout>